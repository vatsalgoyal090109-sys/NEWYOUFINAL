<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Section header (ACTIVE QUESTS / HABITS) -->
    <LinearLayout
        android:id="@+id/wqi_section_header"
        android:layout_width="match_parent"
        android:layout_height="22dp"
        android:gravity="center_vertical"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:background="#08000000"
        android:visibility="gone">

        <TextView
            android:id="@+id/wqi_section_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SECTION"
            android:textColor="#4D607E"
            android:textSize="8sp"
            android:textStyle="bold"
            android:letterSpacing="0.15" />
    </LinearLayout>

    <!-- Quest / habit content row -->
    <LinearLayout
        android:id="@+id/wqi_content"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="14dp"
        android:paddingRight="10dp">

        <!-- Type badge -->
        <TextView
            android:id="@+id/wqi_badge"
            android:layout_width="46dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="DAILY"
            android:textColor="#00D4FF"
            android:textSize="7sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginEnd="10dp" />

        <!-- Name + sub info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/wqi_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Quest name"
                android:textColor="#DDE8FF"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/wqi_sub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="+100 XP"
                android:textColor="#4D607E"
                android:textSize="9sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- DONE button — habits only, when not yet completed -->
        <TextView
            android:id="@+id/wqi_complete_btn"
            android:layout_width="56dp"
            android:layout_height="26dp"
            android:gravity="center"
            android:text="DONE"
            android:textColor="#2ECC71"
            android:textSize="9sp"
            android:textStyle="bold"
            android:background="@drawable/widget_habit_btn"
            android:visibility="gone" />

        <!-- Checkmark — shown when completed -->
        <TextView
            android:id="@+id/wqi_done_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:gravity="center"
            android:text="&#10003;"
            android:textColor="#2ECC71"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
