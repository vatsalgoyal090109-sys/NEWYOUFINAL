<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/wq_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background">

    <!-- Header — tappable to open app -->
    <LinearLayout
        android:id="@+id/wq_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="10dp"
        android:background="#09000000">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/wq_quest_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 PENDING QUESTS"
                android:textColor="#DDE8FF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/wq_habit_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0/0 HABITS DONE"
                android:textColor="#8A9BBF"
                android:textSize="9sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#9654;"
            android:textColor="#4D607E"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1400D4FF" />

    <!-- Scrollable quest + habit list -->
    <ListView
        android:id="@+id/wq_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#0A00D4FF"
        android:dividerHeight="1dp"
        android:scrollbars="none" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/wq_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="All done for today!"
        android:textColor="#4D607E"
        android:textSize="11sp"
        android:visibility="gone" />

</LinearLayout>
